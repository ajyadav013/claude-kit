{
  "id": "python-fastapi",
  "label": "Python · FastAPI",
  "language": "Python 3.11+",
  "overlay_rule": "fastapi-patterns.md",
  "dir": "backend",
  "install_cmd": "pip install -e '.[dev]'",
  "dev_cmd": "uvicorn app.main:app --reload",
  "test_cmd": "pytest",
  "lint_cmd": "ruff check . && mypy app",
  "fmt_cmd": "ruff format .",
  "migrate_cmd": "alembic upgrade head",
  "make_migration_cmd": "alembic revision --autogenerate -m \"<message>\""
}
